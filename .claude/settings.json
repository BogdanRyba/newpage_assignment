{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/guard.sh" },
          { "type": "command", "command": "python3 .claude/hooks/weak_asserts.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/format.sh" },
          { "type": "command", "command": "bash .claude/hooks/tdd_redfirst.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/fast_tests.sh" }]
      }
    ]
  }
}
