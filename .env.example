# Copy to .env and fill in. docker-compose reads .env automatically.
# NEVER commit the real .env.

# --- LLM / embeddings (Gemini by default; all LLM access goes through LangChain) ---
GEMINI_API_KEY=

# Provider is swappable behind the embedder/generator ports.
EMBEDDING_PROVIDER=gemini          # gemini | voyage | local
EMBEDDING_MODEL=models/gemini-embedding-001
LLM_MODEL=gemini-3.5-flash
VOYAGE_API_KEY=                    # only if EMBEDDING_PROVIDER=voyage

# --- Retrieval knobs ---
RERANK_ENABLED=false              # cross-encoder rerank; gate off on CPU-only
TOP_K=8                           # chunks passed to the generator
RETRIEVE_LIMIT=40                 # per-vector candidates before fusion

# --- Determinism / harness ---
# off    : real calls
# record : real calls, persisted to tests/cassettes/*.json
# replay : no network, served from cassettes (CI default)
CASSETTE_MODE=off

# --- Observability ---
LOG_LEVEL=INFO
OTEL_ENABLED=true
# Optional: set to enable LangSmith tracing (otherwise stays local).
LANGCHAIN_TRACING_V2=
LANGCHAIN_API_KEY=

# --- Infra (compose-internal hostnames; override only for local non-docker runs) ---
DATABASE_URL=postgresql+asyncpg://ariadne:ariadne@postgres:5432/ariadne
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687       # only used with --profile graph (stretch)
NEO4J_AUTH=neo4j/ariadnegraph
